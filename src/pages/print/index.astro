---
// Print artifacts — CV (3 pp) + general letterhead (1 p), A4, ⌘P → PDF.
// Generated from the same content base as the site (assignment.md §4.2):
// experience, certifications, education come from src/content/, identity
// and skills from src/data/site.ts. English, public tier only.
// noindex — linked nowhere public; this is a working document.
import { getCollection } from 'astro:content'
import { SITE, UI } from '../../data/site'
import '../../styles/print.css'

const experience = (await getCollection('experience')).sort((a, b) => a.data.order - b.data.order)
const education = (await getCollection('education')).sort((a, b) => a.data.order - b.data.order)
const certs = (await getCollection('certifications')).sort((a, b) => a.data.order - b.data.order)
const projects = await getCollection('projects')
const projTitle = (id: string) => projects.find((p) => p.id === id)?.data.title.en

const byId = Object.fromEntries(experience.map((e) => [e.id, e]))
// page split: recent on p1, earlier on p2, credentials on p3
const xpPage1 = ['freelance', 'eman-head-of-technology'].map((id) => byId[id]).filter(Boolean)
const xpPage2 = ['eman-solution-architect', 'wag', 'provident'].map((id) => byId[id]).filter(Boolean)

const certGroups = (['cloud', 'ea', 'itsm', 'earlier'] as const).map((g) => ({
  label: UI.certGroups[g].en,
  items: certs.filter((c) => c.data.group === g),
}))
const certCols = [
  [certGroups[0], certGroups[2]], // cloud + itsm
  [certGroups[1], certGroups[3]], // ea + earlier
]

const skillRows = [
  { cat: 'Architecture', ids: ['togaf-ea', 'archimate-uml'] },
  { cat: 'Cloud', ids: ['cloud-aws', 'cloud-gcp-azure'] },
  { cat: 'Platform', ids: ['kubernetes', 'devops-cicd', 'iac-monitoring'] },
  { cat: 'Integration', ids: ['eda-microservices', 'integration'] },
  { cat: 'Development', ids: ['dev-node-dotnet'] },
].map((r) => ({ cat: r.cat, vals: r.ids.map((id) => SITE.skills[id].name.en).join(' · ') }))

const now = new Date()
const ref = `VZ-${now.getFullYear()}-001`
const dateStr = now.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })
const roleLine = 'Solution & Cloud Architect'
const cvFootLeft = 'Vojtěch Zicha · Curriculum Vitae · public version, clients anonymized'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Vojtěch Zicha — Print Documents (CV + General)</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="desk">
      <div class="hint">
        <span class="tag"><b>2</b> documents</span>
        <span class="tag">CV — 3 pp</span>
        <span class="tag">General — 1 p</span>
        <span style="margin-left:auto;"
          >Press <span class="kbd">⌘</span><span class="kbd">P</span> → Save as PDF · A4 · margins
          handled</span
        >
      </div>

      <!-- ============ DOCUMENT 1 — CV ============ -->
      <div class="docrule">
        <span class="n">DOC 01</span> Curriculum Vitae <span class="line"></span> A4 · 3 pages
      </div>

      <!-- CV — page 1 -->
      <div class="sheetwrap">
        <span class="cm tl"></span><span class="cm tr"></span><span class="cm bl"></span><span
          class="cm br"></span>
        <div class="sheet">
          <div class="lh">
            <div class="gridband"></div>
            <div class="mark">{SITE.monogram}</div>
            <div class="who">
              <div class="name">{SITE.name}</div>
              <div class="role">{roleLine}</div>
            </div>
            <div class="contact">
              <div><span class="k">E&nbsp;&nbsp;</span><a href={`mailto:${SITE.email}`}>{SITE.email}</a></div>
              <div><span class="k">W&nbsp;&nbsp;</span>vojtechzicha.com</div>
              <div><span class="k">L&nbsp;&nbsp;</span>Prague, Czechia · remote &amp; EU</div>
              <div><span class="k">in</span> /vojtechzicha</div>
            </div>
          </div>

          <div class="sec">
            <div class="sechead">
              <span class="num">01</span><span class="t">Profile</span><span class="rule"></span>
            </div>
            <p class="profile">
              Solution and cloud architect with <b>over 11 years of experience</b> across financial
              services, automotive, energy, and public-sector clients. I design full-scale
              architectures and own delivery end to end — with particular strength in cloud, DevOps,
              and DevSecOps for web, mobile, and IoT platforms. I pair hands-on engineering with
              formal enterprise-architecture practice (TOGAF, ArchiMate) and AWS certification.
              <b>30+ projects delivered</b>; largest team led, <b>22</b>.
            </p>
          </div>

          <div class="sec">
            <div class="sechead">
              <span class="num">02</span><span class="t">Experience</span><span class="rule"></span>
            </div>
            {
              xpPage1.map((e) => (
                <div class="xp">
                  <div class="meta">
                    <div class="period">{e.data.period}</div>
                    {e.data.location && <div>{e.data.location.en}</div>}
                  </div>
                  <div>
                    <h3>{e.data.title.en}</h3>
                    <div class="org">{e.data.org}</div>
                    {e.data.blocks.map((b) => (
                      <>
                        {b.intro && <p class="intro">{b.intro.en}</p>}
                        {b.bullets.length > 0 && (
                          <ul>
                            {b.bullets.map((li) => (
                              <li>
                                <span class="b">→</span>
                                <span>{li.en}</span>
                              </li>
                            ))}
                          </ul>
                        )}
                      </>
                    ))}
                    {e.data.projects.length > 0 && (
                      <div class="stack">
                        {e.data.projects.map(
                          (pid) => projTitle(pid) && <span class="tg">{projTitle(pid)}</span>
                        )}
                      </div>
                    )}
                  </div>
                </div>
              ))
            }
          </div>

          <div class="docfoot">
            <span>{cvFootLeft}</span>
            <span class="pg">01 / 03</span>
          </div>
        </div>
      </div>

      <!-- CV — page 2 -->
      <div class="sheetwrap">
        <span class="cm tl"></span><span class="cm tr"></span><span class="cm bl"></span><span
          class="cm br"></span>
        <div class="sheet">
          <div class="lh">
            <div class="mark">{SITE.monogram}</div>
            <div class="who">
              <div class="name">{SITE.name}</div>
              <div class="role">{roleLine}</div>
            </div>
            <div class="contact">
              <div><span class="k">E&nbsp;&nbsp;</span>{SITE.email}</div>
              <div><span class="k">W&nbsp;&nbsp;</span>vojtechzicha.com</div>
            </div>
          </div>

          <div class="sec">
            <div class="sechead">
              <span class="num">02</span><span class="t">Experience — earlier</span><span class="rule"
              ></span>
            </div>
            {
              xpPage2.map((e) => (
                <div class="xp">
                  <div class="meta">
                    <div class="period">{e.data.period}</div>
                    {e.data.location && <div>{e.data.location.en}</div>}
                  </div>
                  <div>
                    <h3>{e.data.title.en}</h3>
                    <div class="org">{e.data.org}</div>
                    {e.data.blocks.map((b) => (
                      <>
                        {b.intro && <p class="intro">{b.intro.en}</p>}
                        {b.bullets.length > 0 && (
                          <ul>
                            {b.bullets.map((li) => (
                              <li>
                                <span class="b">→</span>
                                <span>{li.en}</span>
                              </li>
                            ))}
                          </ul>
                        )}
                      </>
                    ))}
                    {e.data.projects.length > 0 && (
                      <div class="stack">
                        {e.data.projects.map(
                          (pid) => projTitle(pid) && <span class="tg">{projTitle(pid)}</span>
                        )}
                      </div>
                    )}
                  </div>
                </div>
              ))
            }
          </div>

          <div class="docfoot">
            <span>{cvFootLeft}</span>
            <span class="pg">02 / 03</span>
          </div>
        </div>
      </div>

      <!-- CV — page 3 -->
      <div class="sheetwrap">
        <span class="cm tl"></span><span class="cm tr"></span><span class="cm bl"></span><span
          class="cm br"></span>
        <div class="sheet">
          <div class="lh">
            <div class="mark">{SITE.monogram}</div>
            <div class="who">
              <div class="name">{SITE.name}</div>
              <div class="role">{roleLine}</div>
            </div>
            <div class="contact">
              <div><span class="k">E&nbsp;&nbsp;</span>{SITE.email}</div>
              <div><span class="k">W&nbsp;&nbsp;</span>vojtechzicha.com</div>
            </div>
          </div>

          <div class="sec">
            <div class="sechead">
              <span class="num">03</span><span class="t">Certifications</span><span class="rule"
              ></span>
            </div>
            <div class="grid2">
              {
                certCols.map((col) => (
                  <div>
                    {col.map((g) => (
                      <>
                        <div class="certissuer">{g.label}</div>
                        {g.items.map((c) => (
                          <div class="cert">
                            <span>
                              {c.data.title}
                              <span class="iss">
                                {c.data.issuer}
                                {c.data.url && ` · vojtechzicha.com${c.data.url}`}
                              </span>
                            </span>
                            <span class="y">{c.data.date.slice(0, 4)}</span>
                          </div>
                        ))}
                      </>
                    ))}
                  </div>
                ))
              }
            </div>
          </div>

          <div class="sec">
            <div class="sechead">
              <span class="num">04</span><span class="t">Skills</span><span class="rule"></span>
            </div>
            {
              skillRows.map((r) => (
                <div class="skillrow">
                  <div class="cat">{r.cat}</div>
                  <div class="vals">{r.vals}</div>
                </div>
              ))
            }
          </div>

          <div class="sec">
            <div class="sechead">
              <span class="num">05</span><span class="t">Education &amp; Languages</span><span
                class="rule"></span>
            </div>
            <div class="grid2">
              <div>
                {
                  education.map((ed) => (
                    <div class="edurow">
                      <div class="deg">{ed.data.title.en}</div>
                      <div class="sch">
                        {ed.data.school} · {ed.data.period}
                      </div>
                      {ed.data.note && <div class="note">{ed.data.note.en}</div>}
                    </div>
                  ))
                }
              </div>
              <div class="langrow">
                <div class="l"><b>Czech</b><span>native</span></div>
                <div class="l"><b>English</b><span>full professional (C1)</span></div>
              </div>
            </div>
          </div>

          <div class="docfoot">
            <span>Full project detail — real names, real diagrams — available under NDA</span>
            <span class="pg">03 / 03</span>
          </div>
        </div>
      </div>

      <!-- ============ DOCUMENT 2 — GENERAL ============ -->
      <div class="docrule">
        <span class="n">DOC 02</span> General — correspondence <span class="line"></span> A4 · 1 page
      </div>

      <div class="sheetwrap">
        <span class="cm tl"></span><span class="cm tr"></span><span class="cm bl"></span><span
          class="cm br"></span>
        <div class="sheet">
          <div class="lh">
            <div class="gridband"></div>
            <div class="mark">{SITE.monogram}</div>
            <div class="who">
              <div class="name">{SITE.name}</div>
              <div class="role">{roleLine}</div>
            </div>
            <div class="contact">
              <div><span class="k">E&nbsp;&nbsp;</span><a href={`mailto:${SITE.email}`}>{SITE.email}</a></div>
              <div><span class="k">W&nbsp;&nbsp;</span>vojtechzicha.com</div>
              <div><span class="k">L&nbsp;&nbsp;</span>Prague, Czechia · remote &amp; EU</div>
            </div>
          </div>

          <div class="corr">
            <div class="metaline">
              <span>REF&nbsp;&nbsp;<span class="v">{ref}</span></span>
              <span>DATE&nbsp;&nbsp;<span class="v">{dateStr}</span></span>
            </div>

            <div class="to">
              <span class="lab">To</span>
              <span class="placeholder"
                >[ Recipient name ]<br />[ Company / organisation ]<br />[ Address line ]</span
              >
            </div>

            <div class="re">
              <b>Re:</b>&nbsp;
              <span class="placeholder">[ Subject — e.g. Application for Solution Architect ]</span>
            </div>

            <div class="body">
              <p>Dear <span class="placeholder">[ Name ]</span>,</p>
              <p>
                I am a solution and cloud architect with more than eleven years of experience across
                financial services, automotive, energy, and the public sector. I design full-scale
                architectures and own delivery end to end — from cloud and DevOps platforms to the
                enterprise-architecture practice (TOGAF, ArchiMate) that keeps them coherent.
              </p>
              <p>
                I'm writing because <span class="placeholder"
                  >[ one or two sentences: why this role / project, and the specific outcome you can
                  own ]</span
                >. Most recently I led technology for eMan's Automotive &amp; Industry 4.0 division —
                a cross-functional team of 22 — owning the architecture roadmap, SDLC governance, and
                the design of government-scale platforms such as the digital vignette enforcement
                system.
              </p>
              <p>
                I would welcome a short call to understand <span class="placeholder"
                  >[ the platform / the team / the problem ]</span
                > and where I can be most useful — you can book one directly at
                calendar.app.google/LLnCJUd7MFvhzsfv5. Anonymized case studies are on my site; full
                detail is available under NDA.
              </p>
              <p>Thank you for your time and consideration.</p>
            </div>

            <div class="sign">
              <div>Sincerely,</div>
              <div class="sp"></div>
              <div class="nm">{SITE.name}</div>
              <div class="rl">{roleLine} · {SITE.email}</div>
            </div>
          </div>

          <div class="docfoot">
            <span>{SITE.legal.identity.replace('®', '')}</span>
            <span class="pg">General · letterhead template</span>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
